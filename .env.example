# ===========================================
# Moodle Docker Configuration
# ===========================================
# Copy this file to .env and fill in your values

# -------------------------------------------
# REQUIRED SETTINGS
# -------------------------------------------

# Moodle Version (3.11, 4, 4.1, 4.2, 4.3, 4.4, 4.5, 5.0, etc.)
# Default: 3.11 for backup restoration mode
MOODLE_VERSION=3.11

# PHP Version (7.4 for Moodle 3.11, 8.1 for Moodle 4.x+)
PHP_VERSION=7.4

# MySQL Version (5.7.33 for Moodle 3.11, 8.0 for Moodle 4.x+)
MYSQL_VERSION=5.7.33

# Your domain name (without http/https)
DOMAIN=moodle.example.com

# Email for Let's Encrypt SSL certificate (used by setup-nginx.sh)
CERTBOT_EMAIL=admin@example.com

# -------------------------------------------
# RESTORE MODE (For restoring from backup)
# -------------------------------------------

# Set to 'true' when restoring from an existing Moodle backup
# This skips Moodle installation and uses your existing files
RESTORE_MODE=true

# -------------------------------------------
# PORT SETTINGS
# -------------------------------------------

# Port where Moodle will be exposed (for host nginx to proxy)
MOODLE_PORT=8080

# MySQL port (exposed for debugging, change if 3306 is already in use)
MYSQL_PORT=3306

# -------------------------------------------
# DATABASE SETTINGS
# -------------------------------------------

# MySQL root password
MYSQL_ROOT_PASSWORD=change_this_root_password

# Moodle database name
MYSQL_DATABASE=moodle

# Moodle database user
MYSQL_USER=moodleuser

# Moodle database password
MYSQL_PASSWORD=change_this_moodle_password

# -------------------------------------------
# MOODLE ADMIN SETTINGS
# -------------------------------------------

# Moodle admin username
MOODLE_ADMIN_USER=admin

# Moodle admin password (minimum 8 characters, must include uppercase, lowercase, number, and special char)
MOODLE_ADMIN_PASSWORD=Admin123!

# Moodle admin email
MOODLE_ADMIN_EMAIL=admin@example.com

# Moodle site full name
MOODLE_SITE_FULLNAME="My Moodle Site"

# Moodle site short name
MOODLE_SITE_SHORTNAME="Moodle"

# -------------------------------------------
# PHP SETTINGS (Optional)
# -------------------------------------------

# PHP memory limit
PHP_MEMORY_LIMIT=512M

# PHP upload max filesize
PHP_UPLOAD_MAX_FILESIZE=256M

# PHP post max size
PHP_POST_MAX_SIZE=256M

# PHP max execution time (seconds)
PHP_MAX_EXECUTION_TIME=300

# -------------------------------------------
# ADVANCED SETTINGS (Optional)
# -------------------------------------------

# Enable SSL (set to 'true' when using host nginx with certbot)
# This affects the Moodle wwwroot URL (https vs http)
ENABLE_SSL=true

# Timezone
TIMEZONE=UTC
